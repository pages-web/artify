{
  "meta": {
    "siteName": "artify",
    "visualDirection": "teso-modern",
    "motionLevel": 2,
    "defaultLocale": "mn",
    "locales": ["mn", "en"]
  },
  "colors": {
    "brand": {
      "primary": "#3B82F6",
      "secondary": "#050505",
      "accent": "#7C3AED"
    },
    "neutral": {
      "50": "#0A0A0A",
      "100": "#171717",
      "200": "#262626",
      "300": "#404040",
      "400": "#525252",
      "500": "#737373",
      "600": "#A3A3A3",
      "700": "#D4D4D4",
      "800": "#E5E5E5",
      "900": "#FAFAFA"
    },
    "semantic": {
      "background": "#050505",
      "foreground": "#FAFAFA",
      "card": "#0A0A0A",
      "cardForeground": "#FAFAFA",
      "popover": "#0A0A0A",
      "popoverForeground": "#FAFAFA",
      "primary": "#3B82F6",
      "primaryForeground": "#FFFFFF",
      "secondary": "#111111",
      "secondaryForeground": "#FAFAFA",
      "muted": "#171717",
      "mutedForeground": "#A1A1AA",
      "accent": "#7C3AED",
      "accentForeground": "#FFFFFF",
      "border": "#262626",
      "input": "#262626",
      "ring": "#7C3AED",
      "success": "#10B981",
      "warning": "#F59E0B",
      "destructive": "#EF4444"
    }
  },
  "typography": {
    "families": {
      "display": "Montserrat",
      "body": "Nunito Sans",
      "mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
    },
    "scale": {
      "xs": 12,
      "sm": 13,
      "base": 15,
      "lg": 18,
      "xl": 20,
      "2xl": 24,
      "3xl": 32,
      "4xl": 40,
      "5xl": 56,
      "6xl": 72
    }
  },
  "spacing": {
    "scale": {
      "0": 0,
      "1": 4,
      "2": 8,
      "3": 12,
      "4": 16,
      "5": 24,
      "6": 32,
      "7": 48,
      "8": 64,
      "9": 80,
      "10": 120
    },
    "layout": {
      "maxWidth": "1920px",
      "pagePadding": "48px",
      "sectionGap": "80px",
      "mobilePadding": "16px"
    }
  },
  "radius": {
    "none": 0,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "full": 9999
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px 0 rgb(0 0 0 / 0.05)",
    "md": "0 4px 6px -1px rgb(0 0 0 / 0.1)",
    "lg": "0 10px 15px -3px rgb(0 0 0 / 0.1)"
  },
  "motion": {
    "duration": {
      "fast": 150,
      "normal": 250,
      "slow": 400
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)"
    },
    "spring_configs": {},
    "variants": {
      "fadeInUp": {
        "initial": { "opacity": 0, "y": 24 },
        "animate": { "opacity": 1, "y": 0 },
        "transition": { "duration": 0.6, "ease": "easeOut" }
      }
    },
    "gsap_configs": {}
  }
}
